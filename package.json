{
  "name": "better-auth-email-challenge",
  "version": "0.1.1",
  "description": "Email-bound authentication challenge plugin for Better Auth. One challenge, multiple completion methods (approval link or OTP), with browser-bound session issuance for safe cross-device sign-in.",
  "license": "MIT",
  "author": "Paul Strong (https://github.com/lapluviosilla)",
  "homepage": "https://github.com/lapluviosilla/better-auth-email-challenge#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lapluviosilla/better-auth-email-challenge.git"
  },
  "bugs": {
    "url": "https://github.com/lapluviosilla/better-auth-email-challenge/issues"
  },
  "keywords": [
    "better-auth",
    "better-auth-plugin",
    "auth",
    "authentication",
    "passwordless",
    "magic-link",
    "otp",
    "email-otp",
    "cross-device",
    "sign-in"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.js"
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:matrix": "node scripts/test-matrix.mjs",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepublishOnly": "npm run typecheck && npm run test && npm run build"
  },
  "peerDependencies": {
    "better-auth": "^1.5.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.10",
    "@types/node": "^22.0.0",
    "better-auth": "^1.5.0",
    "better-sqlite3": "^12.0.0",
    "prettier": "^3.8.3",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0",
    "zod": "^4.0.0"
  }
}
