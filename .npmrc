# Supply-chain hardening: refuse to install any package version that was
# published less than 7 days ago. Catches typo-squatted and recently-
# compromised releases before they reach our dependency tree.
#
# Requires npm >= 11. On older npm versions this config is silently ignored;
# the CI workflow upgrades npm before installing for that reason.
#
# npm flattens this into `before = now - (7 * 86400000)`, so it works for
# both top-level installs and transitive dependency resolution.
min-release-age=7
